{
  "manifest_version": 3,
  "name": "Expeek – Excalidraw Viewer",
  "version": "1.0.0",
  "description": "Auto-renders .excalidraw files from GitHub and GitLab in a modal overlay.",
  "permissions": [],
  "host_permissions": [
    "https://github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://gitlab.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*.excalidraw",
        "https://raw.githubusercontent.com/*/*.excalidraw",
        "https://gitlab.com/*/*.excalidraw"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "style.css"],
      "matches": ["https://github.com/*", "https://raw.githubusercontent.com/*", "https://gitlab.com/*"]
    }
  ]
}
