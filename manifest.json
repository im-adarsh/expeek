{
  "manifest_version": 3,
  "name": "Expeek – Excalidraw Viewer",
  "version": "1.0.0",
  "description": "Auto-renders .excalidraw files from GitHub and GitLab.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://gitlab.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*.excalidraw",
        "https://raw.githubusercontent.com/*/*.excalidraw",
        "https://gitlab.com/*/*.excalidraw"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "sandbox": {
    "pages": ["viewer.html"]
  }
}
